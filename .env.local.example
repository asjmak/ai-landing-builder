# ============================================================
# AI Landing Page Builder - Environment Configuration
# ============================================================
#
# Gateway default adalah OpenRouter. Untuk menggunakan 9Router
# (atau gateway OpenAI-compatible lainnya), cukup ubah:
#   AI_BASE_URL  -> endpoint /v1 milik 9Router
#   AI_API_KEY   -> API key 9Router Anda
#
# Aplikasi juga mengizinkan API key dikirim dari UI (field di form)
# untuk kemudahan development, tapi untuk produksi gunakan env ini.

# --- OpenRouter (default) ---
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# --- 9Router (contoh, aktifkan bila dipakai) ---
# AI_BASE_URL=https://api.9router.com/v1
# AI_API_KEY=9r-xxxxxxxxxxxxxxxxxxxxxxxx

# Metadata opsional yang dikirim ke gateway (OpenRouter mewajibkan referer)
AI_SITE_URL=http://localhost:3000
AI_APP_NAME=AI Landing Page Builder
